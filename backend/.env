# URL từ Alchemy hoặc Infura để kết nối với mạng Testnet (Ví dụ: Sepolia)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private Key của ví dùng để deploy (Nhớ dùng ví phụ, không dùng ví chứa tiền thật)
PRIVATE_KEY=your_wallet_private_key_here

# API Key của Pinata (Sẽ dùng sau này để upload file lên IPFS)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key